{
  "name": "honkpad",
  "version": "1.0.0",
  "description": "Honkpad – Live Audio Soundboard",
  "main": "dist-electron/main.js",
  "author": "Jader Moura",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.soundboard.app",
    "productName": "Honkpad",
    "directories": {
      "buildResources": "resources",
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "extraResources": [
      {
        "from": "resources/vbcable",
        "to": "vbcable",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "dist-electron/**",
      "dist/**",
      "!dist/**/sourcemaps/**",
      "node_modules/**"
    ]
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "howler": "^2.2.4",
    "i18next": "^26.0.3",
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.2",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/howler": "^2.2.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  }
}
